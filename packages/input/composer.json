{
    "name": "mkocansey/bladewind-input",
    "description": "BladewindUI — Input field component",
    "keywords": [
        "laravel",
        "blade",
        "tailwindcss",
        "bladewindui",
        "input"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Michael K. Ocansey",
            "email": "mike@bladewindui.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "mkocansey/bladewind-core": "^4.2",
        "mkocansey/bladewind-icon": "^4.2",
        "mkocansey/bladewind-script": "^4.2"
    },
    "autoload": {
        "psr-4": {
            "Mkocansey\\Bladewind\\Input\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mkocansey\\Bladewind\\Input\\InputServiceProvider"
            ]
        }
    }
}
