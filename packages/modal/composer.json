{
    "name": "mkocansey/bladewind-modal",
    "description": "BladewindUI Modal and Modal Icon components",
    "keywords": ["laravel", "blade", "tailwindcss", "bladewindui", "modal", "dialog"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Michael K. Ocansey",
            "email": "mike@bladewindui.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "mkocansey/bladewind-core": "^2.0",
        "mkocansey/bladewind-icon": "^2.0",
        "mkocansey/bladewind-script": "^2.0",
        "mkocansey/bladewind-button": "^2.0",
        "mkocansey/bladewind-spinner": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Mkocansey\\Bladewind\\Modal\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mkocansey\\Bladewind\\Modal\\BladewindModalServiceProvider"
            ]
        }
    }
}
