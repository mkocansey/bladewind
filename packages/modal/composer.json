{
    "name": "mkocansey/bladewind-modal",
    "description": "BladewindUI Modal and Modal Icon components",
    "keywords": [
        "laravel",
        "blade",
        "tailwindcss",
        "bladewindui",
        "modal",
        "dialog"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Michael K. Ocansey",
            "email": "mike@bladewindui.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "mkocansey/bladewind-core": "^4.1",
        "mkocansey/bladewind-icon": "^4.1",
        "mkocansey/bladewind-script": "^4.1",
        "mkocansey/bladewind-button": "^4.1",
        "mkocansey/bladewind-spinner": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "Mkocansey\\Bladewind\\Modal\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mkocansey\\Bladewind\\Modal\\BladewindModalServiceProvider"
            ]
        }
    }
}
