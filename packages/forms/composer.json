        "laravel",
        "blade",
        "tailwindcss",
        "bladewindui",
        "forms"
    ],
    "license": "MIT",
    "type": "metapackage",
    "authors": [
        {
            "name": "Michael K. Ocansey",
            "email": "mike@bladewindui.com"
        }
    ],
    "require": {
        "mkocansey/bladewind-input": "^4.2",
        "mkocansey/bladewind-textarea": "^4.2",
        "mkocansey/bladewind-select": "^4.2",
        "mkocansey/bladewind-checkbox": "^4.2",
        "mkocansey/bladewind-radio": "^4.2",
        "mkocansey/bladewind-toggle": "^4.2",
        "mkocansey/bladewind-datepicker": "^4.2",
        "mkocansey/bladewind-timepicker": "^4.2",
        "mkocansey/bladewind-colorpicker": "^4.2",
        "mkocansey/bladewind-filepicker": "^4.2",
        "mkocansey/bladewind-slider": "^4.2",
        "mkocansey/bladewind-checkcards": "^4.2",
        "mkocansey/bladewind-number": "^4.2",
        "mkocansey/bladewind-code": "^4.2"
