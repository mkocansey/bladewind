{
    "name": "mkocansey/bladewind",
    "description": "BladewindUI — elegant Laravel Blade UI components powered by TailwindCSS",
    "keywords": ["laravel", "blade", "tailwindcss", "ui components", "bladewindui"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Michael K. Ocansey",
            "email": "mike@bladewindui.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "mkocansey/bladewind-core":                 "^2.0",
        "mkocansey/bladewind-icon":                 "^2.0",
        "mkocansey/bladewind-script":               "^2.0",
        "mkocansey/bladewind-spinner":              "^2.0",
        "mkocansey/bladewind-button":               "^2.0",
        "mkocansey/bladewind-alert":                "^2.0",
        "mkocansey/bladewind-modal":                "^2.0",
        "mkocansey/bladewind-table":                "^2.0",
        "mkocansey/bladewind-forms":                "^2.0",
        "mkocansey/bladewind-content":              "^2.0",
        "mkocansey/bladewind-navigation":           "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Mkocansey\\Bladewind\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mkocansey\\Bladewind\\BladewindServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-update-cmd": [
            "@php -r \"if (file_exists('artisan')) passthru('php artisan vendor:publish --tag=bladewind-public --force');\"",
            "@php -r \"if (file_exists('artisan')) passthru('php artisan vendor:publish --tag=bladewind-lang --force');\""
        ]
    }
}
