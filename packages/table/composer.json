{
    "name": "mkocansey/bladewind-table",
    "description": "BladewindUI Table component — searchable, sortable, paginated data table",
    "keywords": [
        "laravel",
        "blade",
        "tailwindcss",
        "bladewindui",
        "table",
        "datatable"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Michael K. Ocansey",
            "email": "mike@bladewindui.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "mkocansey/bladewind-core": "^4.1",
        "mkocansey/bladewind-icon": "^4.1",
        "mkocansey/bladewind-script": "^4.1",
        "mkocansey/bladewind-spinner": "^4.1",
        "mkocansey/bladewind-button": "^4.1",
        "mkocansey/bladewind-input": "^4.1",
        "mkocansey/bladewind-checkbox": "^4.1",
        "mkocansey/bladewind-empty-state": "^4.1",
        "mkocansey/bladewind-pagination": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "Mkocansey\\Bladewind\\Table\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mkocansey\\Bladewind\\Table\\BladewindTableServiceProvider"
            ]
        }
    }
}
