{
    "name": "mkocansey/bladewind-table",
    "description": "BladewindUI Table component — searchable, sortable, paginated data table",
    "keywords": ["laravel", "blade", "tailwindcss", "bladewindui", "table", "datatable"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Michael K. Ocansey",
            "email": "mike@bladewindui.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "mkocansey/bladewind-core":       "^2.0",
        "mkocansey/bladewind-icon":       "^2.0",
        "mkocansey/bladewind-script":     "^2.0",
        "mkocansey/bladewind-spinner":    "^2.0",
        "mkocansey/bladewind-button":     "^2.0",
        "mkocansey/bladewind-input":      "^2.0",
        "mkocansey/bladewind-checkbox":   "^2.0",
        "mkocansey/bladewind-empty-state":"^2.0",
        "mkocansey/bladewind-pagination": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Mkocansey\\Bladewind\\Table\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mkocansey\\Bladewind\\Table\\BladewindTableServiceProvider"
            ]
        }
    }
}
