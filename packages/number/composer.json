{
    "name": "mkocansey/bladewind-number",
    "description": "BladewindUI — Numeric stepper component",
    "keywords": [
        "laravel",
        "blade",
        "tailwindcss",
        "bladewindui",
        "number"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Michael K. Ocansey",
            "email": "mike@bladewindui.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "mkocansey/bladewind-core": "^4.1",
        "mkocansey/bladewind-script": "^4.1",
        "mkocansey/bladewind-input": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "Mkocansey\\Bladewind\\Number\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mkocansey\\Bladewind\\Number\\NumberServiceProvider"
            ]
        }
    }
}
