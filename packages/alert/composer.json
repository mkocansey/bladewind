{
    "name": "mkocansey/bladewind-alert",
    "description": "BladewindUI Alert, Notification, and Bell components",
    "keywords": ["laravel", "blade", "tailwindcss", "bladewindui", "alert", "notification"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Michael K. Ocansey",
            "email": "mike@bladewindui.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "mkocansey/bladewind-core": "^2.0",
        "mkocansey/bladewind-icon": "^2.0",
        "mkocansey/bladewind-script": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Mkocansey\\Bladewind\\Alert\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mkocansey\\Bladewind\\Alert\\BladewindAlertServiceProvider"
            ]
        }
    }
}
