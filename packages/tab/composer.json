{
    "name": "mkocansey/bladewind-tab",
    "description": "BladewindUI — Tab group component",
    "keywords": [
        "laravel",
        "blade",
        "tailwindcss",
        "bladewindui",
        "tab"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Michael K. Ocansey",
            "email": "mike@bladewindui.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "mkocansey/bladewind-core": "^4.0",
        "mkocansey/bladewind-icon": "^4.0",
        "mkocansey/bladewind-script": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Mkocansey\\Bladewind\\Tab\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mkocansey\\Bladewind\\Tab\\TabServiceProvider"
            ]
        }
    }
