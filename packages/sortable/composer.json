{
    "name": "mkocansey/bladewind-sortable",
    "description": "BladewindUI — Drag and drop sortable list component (powered by SortableJS)",
    "keywords": [
        "laravel",
        "blade",
        "tailwindcss",
        "bladewindui",
        "sortable",
        "drag-and-drop"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Michael K. Ocansey",
            "email": "mike@bladewindui.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "mkocansey/bladewind-core": "^4.2.1",
        "mkocansey/bladewind-icon": "^4.2.1",
        "mkocansey/bladewind-script": "^4.2.1"
    },
    "autoload": {
        "psr-4": {
            "Mkocansey\\Bladewind\\Sortable\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mkocansey\\Bladewind\\Sortable\\BladewindSortableServiceProvider"
            ]
        }
    }
}
