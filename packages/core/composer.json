{
    "name": "mkocansey/bladewind-core",
    "description": "Shared foundation for BladewindUI — helpers, CSS variables, and base JS",
    "keywords": [
        "laravel",
        "blade",
        "tailwindcss",
        "bladewindui"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Michael K. Ocansey",
            "email": "mike@bladewindui.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Mkocansey\\Bladewind\\Core\\": "src/"
        },
        "files": [
            "src/BladewindHelpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mkocansey\\Bladewind\\Core\\BladewindCoreServiceProvider"
            ]
        }
    }
}
